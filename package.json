{
  "name": "forward-widget-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node -e \"if(process.env._OPENNEXT==='1'){require('child_process').execSync('npx next build --webpack',{stdio:'inherit',shell:true})}else{process.env._OPENNEXT='1';require('child_process').execSync('npx @opennextjs/cloudflare build',{stdio:'inherit',shell:true})}\"",
    "build:cf": "node -e \"process.env._OPENNEXT='1';require('child_process').execSync('npx @opennextjs/cloudflare build',{stdio:'inherit',shell:true});\" && node -e \"const fs=require('fs');let c=fs.readFileSync('.open-next/middleware/handler.mjs','utf8');c=c.replace(/^import \\* as process from [\\\"']node:process[\\\"'];/gm,'import process from \\\"node:process\\\";');fs.writeFileSync('.open-next/middleware/handler.mjs',c);let e=fs.readFileSync('.open-next/cloudflare/next-env.mjs','utf8');let lines=[...new Set(e.split('\\n').filter(l=>l.trim()))];fs.writeFileSync('.open-next/cloudflare/next-env.mjs',lines.join('\\n'));\"",
    "build:docker": "next build",
    "start": "next start",
    "lint": "eslint",
    "d1:init": "wrangler d1 execute forward-widget-hub-db --file=d1-schema.sql"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "ali-oss": "^6.23.0",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "@tailwindcss/postcss": "^4",
    "@types/ali-oss": "^6.23.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@opennextjs/cloudflare": "^1",
    "wrangler": "^4"
  }
}